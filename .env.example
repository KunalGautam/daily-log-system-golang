# Server
SERVER_PORT=8080
GIN_MODE=debug
BASE_URL=http://localhost:8080

# Database (SQLite - development)
DB_DRIVER=sqlite
DB_DSN=./data/life_log.db

# Database (PostgreSQL - production)
# DB_DRIVER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=lifelog
# DB_PASSWORD=changeme
# DB_NAME=lifelog
# DB_SSLMODE=disable

# Database (MySQL - optional)
# DB_DRIVER=mysql
# DB_DSN=user:password@tcp(localhost:3306)/lifelog?charset=utf8mb4&parseTime=True&loc=Local

# JWT Authentication
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRY=168h

# Argon2id Password Hashing
ARGON2_TIME=3
ARGON2_MEMORY=65536
ARGON2_THREADS=4
ARGON2_KEY_LENGTH=32

# TOTP 2FA
TOTP_ISSUER=LifeLog

# WebAuthn
WEBAUTHN_RPID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:5173

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_BURST=10

# MQTT
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=life-log-backend
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1

# ntfy Notifications
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=life-log
NTFY_TOKEN=
NTFY_ENABLED=false

# SMTP Email
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=noreply@lifelog.app
# SMTP_FROM_NAME=LifeLog
